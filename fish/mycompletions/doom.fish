# doom
complete -c doom -x -a sync    --description 'synchronize your private config with Doom'
complete -c doom -x -a upgrade --description 'update Doom to the latest release'
complete -c doom -x -a doctor  --description 'diagnose common issues with your system'
complete -c doom -x -a env     --description 'dump a snapshot of your shell environment that doom will load'
complete -c doom -x -a build   --description 'recompile all installed packages'